# ── 지원 계정 (EC2 인스턴스 프로파일로 자동 인증, 별도 키 불필요) ──────────────
# Bedrock KB · Titan Embed · Haiku/Nova · DynamoDB · S3 모두 여기
AWS_REGION=us-east-1

# ── 개인 계정 (Sonnet 4.6 Vision 시연 한정, 서울 리전) ────────────────────────
# 방법 A: 액세스 키 직접 입력
AI_AWS_ACCESS_KEY_ID=AKIA...
AI_AWS_SECRET_ACCESS_KEY=...
AI_AWS_SESSION_TOKEN=          # 임시 자격증명(STS) 쓸 때만

# 방법 B: AWS CLI 프로파일 (~/.aws/credentials 에 [personal] 설정된 경우)
# AI_AWS_PROFILE=personal

AI_AWS_REGION=ap-northeast-2   # 서울 — Sonnet 4.6 Global cross-region inference profile

# ── Bedrock 모델 ──────────────────────────────────────────────────────────
# 트랙 B (지원 계정, 1만 분류 시연 10개): Haiku 4.5 또는 Nova
# 트랙 C (개인 계정, Vision 시연 10개): Sonnet 4.6 Global inference profile
BEDROCK_LLM_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_VISION_MODEL_ID=global.anthropic.claude-sonnet-4-6
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# ── Bedrock Knowledge Base (지원 계정, 강사 제공) ─────────────────────────
# 2026-05-25: kmuproj-02·10·11 Role에 Put/Get/List/Delete 권한 부여 완료.
# 규약 (사고 방지) — docs/plans/be-aws-wiring.md B12 참조:
#   1. prefix 분리 — clinic-focus/prod/ (운영) vs clinic-focus/probe/ (실험)
#   2. 운영 코드 DeleteObject 호출 금지 (덮어쓰기·soft-delete만)
#   3. metadata 에 team_id="clinic-focus" 필수 (retrieve 필터로 격리)
KB_ID=GTBJ6HLFDK                              # kmuproj-team-03
KB_DATA_SOURCE_ID=PLC6QYALDU                  # main-datasource
KB_DATASOURCE_S3_BUCKET=kmuproj-02-vector
KB_DATASOURCE_S3_PREFIX=clinic-focus/prod/

# ── DynamoDB (지원 계정, 인스턴스 프로파일로 인증) ──────────────────────────
# 같은 계정 내 다른 프로젝트와 충돌 방지용. 계정 분리(BE=kmuproj-02, AI=kmuproj-10)
# 이후 팀 충돌 위험은 사라졌지만 안전장치로 권장.
TABLE_PREFIX=clinic-

# ── 크롤러 ────────────────────────────────────────────────────────────────
# S3Adapter 가 boto3 로 전환되면 CRAWL_DATA_DIR 대신 S3_CRAWL_BUCKET 사용.
# 버킷명은 본인 username 접두사 — BE=kmuproj-02-*, AI=kmuproj-10-*
CRAWL_DATA_DIR=/home/ec2-user/clinic-focus/data/crawl
S3_CRAWL_BUCKET=kmuproj-10-clinic-focus-crawl
HIRA_API_KEY=

# ── 외부 API ─────────────────────────────────────────────────────────────
KAKAO_REST_API_KEY=
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=

# ── API 서버 ──────────────────────────────────────────────────────────────
PORT=8000

# ── AI 비용 제어 ──────────────────────────────────────────────────────────
MAX_VISION_IMAGES=10
MAX_LLM_DEMO_HOSPITALS=10        # 트랙 B·C 시연 한도 (지원 계정 Bedrock 10개 제약)
CONFIDENCE_THRESHOLD_HIGH=95
CONFIDENCE_THRESHOLD_LOW=70







