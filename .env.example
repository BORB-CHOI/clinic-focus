# clinic-focus 환경변수 예시
#
# 사용법:
#   cp .env.example .env
#   본인 트랙(BE 또는 AI)에 해당하는 값만 채우면 됨.
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │ 계정 분리 (2026-05-25 결정)                                          │
# │   BE 트랙 = kmuproj-02 계정                                          │
# │   AI 트랙 = kmuproj-10 계정                                          │
# │ → DynamoDB·S3 각자 따로. 강사 제공 KB(kmuproj-team-03)만 공유.       │
# │   상세: docs/plans/be-aws-wiring.md · docs/plans/task-queue.md       │
# └─────────────────────────────────────────────────────────────────────┘


# ── 지원 계정 (BE·AI 공통) ───────────────────────────────────────────────────
# EC2 인스턴스 프로파일로 자동 인증. Bedrock KB·Titan·Haiku/Nova·DynamoDB·S3 전부 여기.
# 로컬 PC에서는 호출 불가 — Access Key 발급 안 됨. 코드 실행은 EC2(VSCode Remote-SSH)에서.
AWS_REGION=us-east-1


# ── 개인 계정 (AI 트랙 전용) ─────────────────────────────────────────────────
# Sonnet 4.6 Vision 시연 한정. BE 담당자는 비워둬도 됨.
# 방법 A: 액세스 키 직접 입력
AI_AWS_ACCESS_KEY_ID=AKIA...
AI_AWS_SECRET_ACCESS_KEY=...
AI_AWS_SESSION_TOKEN=          # 임시 자격증명(STS) 쓸 때만

# 방법 B: AWS CLI 프로파일 (~/.aws/credentials 에 [personal] 설정된 경우)
# AI_AWS_PROFILE=personal

AI_AWS_REGION=ap-northeast-2   # 서울 — Sonnet 4.6 Global cross-region inference profile


# ── Bedrock 모델 (BE·AI 공통) ───────────────────────────────────────────────
# 트랙 B (지원 계정, 시연 10개): Haiku 4.5 또는 Nova
# 트랙 C (개인 계정, Vision 시연 10개): Sonnet 4.6 Global inference profile
BEDROCK_LLM_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_VISION_MODEL_ID=global.anthropic.claude-sonnet-4-6
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0


# ── Bedrock Knowledge Base (BE·AI 공통, 강사 제공 공유 자원) ────────────────
# kmuproj-02·10·11 Role에 Put/Get/List/Delete 권한 부여 완료 (2026-05-25).
# 규약 (사고 방지) — docs/plans/be-aws-wiring.md B12 참조:
#   1. prefix 분리 — clinic-focus/prod/ (운영) vs clinic-focus/probe/ (실험)
#   2. 운영 코드 DeleteObject 호출 금지 (덮어쓰기·soft-delete만)
#   3. metadata 에 team_id="clinic-focus" 필수 (retrieve 필터로 격리)
# 버킷 이름이 kmuproj-02-* 라고 BE 전용은 아님. 강사가 02 명의로 만든 공유 버킷.
KB_ID=GTBJ6HLFDK                              # kmuproj-team-03
KB_DATA_SOURCE_ID=PLC6QYALDU                  # main-datasource
KB_DATASOURCE_S3_BUCKET=kmuproj-02-vector
KB_DATASOURCE_S3_PREFIX=clinic-focus/prod/


# ── DynamoDB (BE·AI 각자 자기 계정) ─────────────────────────────────────────
# 강사 정책상 자원 이름은 무조건 username prefix(kmuproj-XX-*) 로 시작해야 함.
# DynamoDB·S3·EC2 모두 동일 규칙 (EC2 인스턴스 이름도 kmuproj-10-ec2 처럼 박혀 있음).
# 다른 prefix(예: clinic-) 시도 시 CreateTable AccessDeniedException.
#   BE 담당자(kmuproj-02): TABLE_PREFIX=kmuproj-02-clinic-
#   AI 담당자(kmuproj-10): TABLE_PREFIX=kmuproj-10-clinic-
TABLE_PREFIX=


# ── 크롤러 저장소 (BE·AI 각자 자기 계정) ────────────────────────────────────
# S3_CRAWL_BUCKET 은 본인 username 접두사로 바꿔서 .env 에 채울 것.
#   BE 담당자(kmuproj-02): S3_CRAWL_BUCKET=kmuproj-02-clinic-focus-crawl
#   AI 담당자(kmuproj-10): S3_CRAWL_BUCKET=kmuproj-10-clinic-focus-crawl
# .env.example 의 기본값은 의도적으로 비워둠 — 두 계정 모두 본인이 직접 채우게.
S3_CRAWL_BUCKET=

# Fallback only — S3Adapter 가 boto3 로 완전 전환된 이후엔 사용 안 함.
# 로컬 단위 테스트 등 S3 권한 없는 환경에서만 의미가 있음.
CRAWL_DATA_DIR=/home/ec2-user/clinic-focus/data/crawl


# ── 외부 API 키 (각자 발급) ─────────────────────────────────────────────────
# HIRA: 공공데이터포털(data.go.kr)에서 "건강보험심사평가원 병원·약국 찾기서비스" 인증키.
#   BE·AI 양쪽이 호출량 분담 안 맞으면 throttle 가능 — 각자 키 발급 권장.
HIRA_API_KEY=
KAKAO_REST_API_KEY=
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=


# ── API 서버 ──────────────────────────────────────────────────────────────
PORT=8000


# ── AI 비용 제어 ──────────────────────────────────────────────────────────
MAX_VISION_IMAGES=10
MAX_LLM_DEMO_HOSPITALS=10        # 트랙 B·C 시연 한도 (지원 계정 Bedrock 제약)
CONFIDENCE_THRESHOLD_HIGH=95
CONFIDENCE_THRESHOLD_LOW=70
