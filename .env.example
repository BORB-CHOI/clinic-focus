# clinic-focus 환경변수. cp .env.example .env 후 본인 트랙 값 채우기.
# 계정 분리: BE=kmuproj-02, AI=kmuproj-10. KB만 공유. 자세한 건 docs/setup/aws-onboarding.md.


# ── 지원 계정 (EC2 인스턴스 프로파일 자동 인증) ─────────────────────────
AWS_REGION=us-east-1


# ── 개인 계정 (AI 트랙 Sonnet 4.6 Vision 전용) ─────────────────────────
AI_AWS_ACCESS_KEY_ID=AKIA...
AI_AWS_SECRET_ACCESS_KEY=...
AI_AWS_SESSION_TOKEN=                # STS·SSO 임시 자격증명일 때만
# AI_AWS_PROFILE=personal            # 대안: ~/.aws/credentials 프로파일
AI_AWS_REGION=ap-northeast-2


# ── Bedrock 모델 ────────────────────────────────────────────────────────
BEDROCK_LLM_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_VISION_MODEL_ID=global.anthropic.claude-sonnet-4-6
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0


# ── Bedrock KB (강사 제공 공유, team_id="clinic-focus" 메타 필수) ────────
KB_ID=GTBJ6HLFDK
KB_DATA_SOURCE_ID=PLC6QYALDU
KB_DATASOURCE_S3_BUCKET=kmuproj-02-vector
KB_DATASOURCE_S3_PREFIX=clinic-focus/prod/


# ── DynamoDB (콘솔에서 수동 생성, 스키마는 task-queue.md §3) ────────────
# BE: kmuproj-02-team3-backend  /  AI: kmuproj-10-clinic-Main
DYNAMO_TABLE=
TABLE_PREFIX=                        # Deprecated, scratch/ 삭제와 함께 제거


# ── S3 크롤링 저장소 (콘솔에서 수동 생성) ────────────────────────────────
# BE: kmuproj-02-team3-backend  /  AI: kmuproj-10-clinic-focus-crawl
S3_CRAWL_BUCKET=
CRAWL_DATA_DIR=/home/ec2-user/clinic-focus/data/crawl   # scratch/ 우회 스크립트용


# ── 외부 API 키 ─────────────────────────────────────────────────────────
# HIRA 심평원 공공 API — 병원 메타·전문의·기기 신고
HIRA_API_KEY=

# 카카오 REST API (BE 서버 사이드) — 로컬 API 키워드 검색·좌표 변환
KAKAO_REST_API_KEY=

# 카카오 JavaScript SDK (FE 브라우저) — 지도 표시·마커
# 같은 카카오 앱의 "JavaScript 키". Web 플랫폼 도메인 등록 필수
VITE_KAKAO_MAP_KEY=

# 네이버 개발자센터 검색 API — 블로그·지역 검색
# (변수명은 _MAP 이지만 실제로는 openapi.naver.com 의 검색 API 키.
#  NCP Maps API 키 아님. Phase B 에서 블로그 시그널 + 지역 검색에 사용)
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=

# 구글 Cloud Places API (New) + Geocoding API
# 4 시그널 中 후기 한 축 (Place Details + Reviews 최대 5건) + 좌표 폴백
# 결제수단 등록 필수. 월 $200 무료 크레딧
GOOGLE_PLACES_API_KEY=


# ── 서버·AI 비용 제어 ──────────────────────────────────────────────────
PORT=8000
MAX_VISION_IMAGES=10
MAX_LLM_DEMO_HOSPITALS=10
CONFIDENCE_THRESHOLD_HIGH=95
CONFIDENCE_THRESHOLD_LOW=70
