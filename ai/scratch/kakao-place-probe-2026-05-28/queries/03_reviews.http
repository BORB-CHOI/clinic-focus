# 카카오 후기 — `place-api.map.kakao.com/places/tab/reviews/kakaomap/{id}`
# panel3 의 kakaomap_review 가 1페이지를 이미 포함. 본 엔드포인트는 후속 페이지·정렬·필터 옵션용.

GET https://place-api.map.kakao.com/places/tab/reviews/kakaomap/{place_id}?order={RECOMMENDED|LATEST}&only_photo_review={true|false}
Referer: https://place.map.kakao.com/{place_id}
Origin: https://place.map.kakao.com
pf: web
Accept: application/json, text/plain, */*

# 응답 골격:
# {
#   "score_set": {
#     "review_count": 303,
#     "total_score": ...,
#     "average_score": 4.6,
#     "strength_counts": [{"id": 2, "count": 164}, {"id": 10, "count": 145}, ...],   # 카카오 강점 집계
#     "strength_uv": ...
#   },
#   "strength_description": [
#     {"id": 13, "name": "가격",  "icon_url": "..."},
#     {"id": 10, "name": "전문성","icon_url": "..."},
#     {"id":  2, "name": "친절",  "icon_url": "..."},
#     {"id":  4, "name": "주차",  "icon_url": "..."}
#   ],
#   "reviews": [
#     {
#       "review_id": "...",
#       "contents": "한약비싼값어치는함 ~",          # 본문 raw
#       "star_rating": 4,                              # 0~5 정수 (네이버는 병원 카테고리에서 null)
#       "photo_count": 0,
#       "photos": [{"url": "...", "kakaomap_review_photo_meta": {"owner": {...}}}],
#       "strength_ids": [10, 4],                       # 작성자가 선택한 강점
#       "registered_at": "2026-05-14 12:59:49",
#       "updated_at": "...",
#       "status": ...,
#       "meta": {...}
#     }, ...
#   ],
#   "has_next": true,
#   "has_my_review": false,
#   "timeline_score_table": ...
# }
#
# 발견:
#   1) strength_description 라벨 고정 4종 (가격/전문성/친절/주차). 카테고리 무관 동일 매핑. 네이버 themes/votedKeyword 카테고리별 분기와 다름
#   2) 병원 카테고리도 star_rating·집계 빈도 노출 — 네이버가 막아둔 시그널을 카카오는 노출
#   3) 1 호출 11~20건. `?page=2` 박아도 같은 items 반환 — **페이지네이션 키 미실측** (cursor/offset 후보. 다음 세션)
#   4) `only_photo_review=true` 필터 가능 — 사진 후기만 가져와 박스 2 Vision 시드 노이즈 감소
#   5) photos[].kakaomap_review_photo_meta.owner = 작성자 카카오톡 ID·닉네임·프로필 사진. raw 그대로 저장 시 개인정보 노출 — 마스킹 필요
